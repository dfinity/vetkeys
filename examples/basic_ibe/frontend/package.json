    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.0",
    "tslib": "^2.8.1",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.35.1",
    "vite": "^6.4.1",
    "vite-plugin-environment": "^1.1.3"
  },
  "dependencies": {
    "@dfinity/vetkeys": "file:../../../frontend/ic_vetkeys",
    "@icp-sdk/auth": "^5.0.0",
    "@icp-sdk/core": "^5.2.1"
